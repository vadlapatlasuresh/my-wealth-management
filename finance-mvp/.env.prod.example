# ============================================================
#  PRODUCTION env template for docker-compose.prod.yml
#  Copy to .env.prod and fill real values. NEVER commit .env.prod.
#  Secrets should come from Doppler / a secret manager — this file
#  documents the full set of variables the stack expects.
# ============================================================

# --- Images / deploy ---
GHCR_OWNER=your-github-username-or-org   # ghcr.io/<owner>/wealth-<service>
TAG=latest                               # set to the git SHA promoted from QA

# --- Public hostnames / TLS (Caddy) ---
API_DOMAIN=api.example.com               # the API hostname Caddy gets a cert for
ACME_EMAIL=you@example.com               # Let's Encrypt account email
# Comma-separated web origin(s) allowed by gateway CORS. NO wildcard in prod.
# MUST include the ops origin once OPS_DOMAIN is set, or every ops-portal call fails CORS.
WEB_ORIGINS=https://app.example.com,https://ops.example.com

# --- Ops portal origin ------------------------------------------------------------
# The hostname Caddy serves the ops portal on. Leave BLANK until the DNS record exists:
# unset, Caddy falls back to ops.localhost, issues an internal cert, and never contacts
# Let's Encrypt — so the ops site block is inert and harmless.
#
# Before setting this:
#   1. The A-record must resolve to THIS VM  (dig +short ops.example.com  ->  the VM IP)
#   2. It must be GREY-CLOUD / "DNS only" in Cloudflare. Behind the orange cloud, the
#      ACME HTTP-01 challenge is answered by Cloudflare's edge and Caddy never gets a
#      cert — and ops traffic (customer PII, SSN reveals, refunds) would be decrypted at
#      a third party, which app.example.com does not do today.
#   3. Add the origin to WEB_ORIGINS above.
OPS_DOMAIN=
# The public API origin the web SPA calls. deploy.sh bakes this into the build as
# VITE_API_BASE. Same-origin here: Caddy serves the SPA and /api on this domain.
WEB_API_BASE=https://app.example.com

# --- Shared auth (MUST be identical across all services) ---
# Generate: openssl rand -base64 48   (DO NOT reuse the public demo secret)
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_secret

# --- Encryption at rest (account-aggregation-service) ---
# AES key material used to encrypt Plaid access tokens in the DB. REQUIRED.
# Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=CHANGE_ME_generate_a_32_byte_random_key

# --- Audit ingest (internal shared key the gateway/services present to audit-service) ---
# Generate: openssl rand -base64 32
AUDIT_INGEST_KEY=CHANGE_ME_internal_audit_key

# --- Deal Room: internal notification ingest (real-estate -> notification on new lead) ---
# Same value in real-estate-service and notification-service. Generate: openssl rand -base64 32
NOTIFICATIONS_INTERNAL_KEY=CHANGE_ME_internal_notification_key

# --- Centralized secret store (secrets-service) ---
# Internal key services present when reading secrets. Generate: openssl rand -base64 32
SECRETS_INTERNAL_KEY=CHANGE_ME_internal_secrets_key
# KEK provider: local | kms.
#   kms (recommended): KEK lives in Cloud KMS — NO key material here. Run terraform in
#     infra/gcp, then set: SECRETS_PROVIDER=kms and SECRETS_KMS_KEY_NAME=<terraform output
#     -raw secrets_kms_key_name>, and leave SECRETS_MASTER_KEY blank.
#   local: derive the KEK from SECRETS_MASTER_KEY below (the one interim secret).
SECRETS_PROVIDER=local
SECRETS_KMS_KEY_NAME=
# Used only when SECRETS_PROVIDER=local. Generate: openssl rand -base64 32.
SECRETS_MASTER_KEY=CHANGE_ME_secrets_master_kek
# secrets-service Postgres (schema-per-service, like the others)
SECRETS_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=secrets
SECRETS_DATABASE_USER=CHANGE_ME
SECRETS_DATABASE_PASSWORD=CHANGE_ME

# --- Database (Neon) ---
# One Neon project, a branch per environment; schema-per-service in that branch.
# JDBC form: jdbc:postgresql://<neon-host>/<db>?sslmode=require&user=<u>&password=<p>
# (Or split user/password into the *_DATABASE_USER/PASSWORD vars below.)
AUTH_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=auth
AUTH_DATABASE_USER=wealth
AUTH_DATABASE_PASSWORD=CHANGE_ME

AGG_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=aggregation
AGG_DATABASE_USER=wealth
AGG_DATABASE_PASSWORD=CHANGE_ME

CORE_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=core
CORE_DATABASE_USER=wealth
CORE_DATABASE_PASSWORD=CHANGE_ME

RE_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=real_estate
RE_DATABASE_USER=wealth
RE_DATABASE_PASSWORD=CHANGE_ME

BIZ_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=business
BIZ_DATABASE_USER=wealth
BIZ_DATABASE_PASSWORD=CHANGE_ME

AI_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=ai
AI_DATABASE_USER=wealth
AI_DATABASE_PASSWORD=CHANGE_ME

PAY_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=payments
PAY_DATABASE_USER=wealth
PAY_DATABASE_PASSWORD=CHANGE_ME

NOTIF_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=notifications
NOTIF_DATABASE_USER=wealth
NOTIF_DATABASE_PASSWORD=CHANGE_ME

CONFIG_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=platform_config
CONFIG_DATABASE_USER=wealth
CONFIG_DATABASE_PASSWORD=CHANGE_ME

AUDIT_DATABASE_URL=jdbc:postgresql://HOST/wealth?sslmode=require&currentSchema=audit
AUDIT_DATABASE_USER=wealth
AUDIT_DATABASE_PASSWORD=CHANGE_ME

# --- Provider toggles (each defaults to a working offline mock) ---
# Set the *_PROVIDER flag AND the matching key(s) to go live. With the flag at
# its default, the service uses the deterministic mock and ignores the keys.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Real-estate valuation: mock | rentcast
REALESTATE_PROVIDER=mock
REALESTATE_PROVIDER_BASE_URL=https://api.rentcast.io/v1
REALESTATE_PROVIDER_API_KEY=

# Business financials: mock | quickbooks  (QuickBooks Online OAuth2)
BUSINESS_PROVIDER=mock
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
# Sandbox API base is https://sandbox-quickbooks.api.intuit.com; prod is https://quickbooks.api.intuit.com
QBO_API_BASE_URL=https://quickbooks.api.intuit.com
QBO_REDIRECT_URI=https://api.example.com/api/v1/business/oauth/callback
# Where the OAuth callback bounces the browser back to (the web app origin).
APP_WEB_URL=https://app.example.com

# AI insights: mock | anthropic | gemini
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-opus-4-8
# Google Gemini. Used by the chat ModelRouter whenever GEMINI_API_KEY is set (regardless of
# AI_PROVIDER), and for the insight cards when AI_PROVIDER=gemini.
#
# Default is the gemini-flash-latest ALIAS, which tracks the current flash model. This is
# deliberate: pinned names rot and their free-tier eligibility varies per project. Observed
# on this project — gemini-2.5-flash returns 404 "no longer available to new users",
# gemini-3.5-flash returns 429 "prepayment credits are depleted" (paid-only), while
# gemini-flash-latest resolves to a model the free tier actually serves.
#
# Trade-off: the alias can change the underlying model (and its cost/latency) without warning.
# Pin an explicit name instead if you need reproducibility and your project can call it.
#
# Two distinct failure modes, both of which degrade SILENTLY to mock replies:
#   404 NOT_FOUND         -> wrong/retired model name. Change the model.
#   429 RESOURCE_EXHAUSTED-> account/model has no funding or free-tier quota. Fix billing,
#                            or use a key from a project with billing DISABLED.
# Check `docker logs wealth-ai-insights-service | grep -i "chat via"` to tell them apart.
#
# A model appearing in ListModels does NOT mean your key may call it — eligibility is
# enforced per project on generateContent. Always verify before pinning:
#   curl -s https://generativelanguage.googleapis.com/v1beta/models/<model>:generateContent \
#     -H "x-goog-api-key: $GEMINI_API_KEY" -H 'content-type: application/json' \
#     -d '{"contents":[{"role":"user","parts":[{"text":"say OK"}]}]}'
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Payments: mock | stripe
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notifications: each channel is mock | <real>
COMMS_PROVIDER_EMAIL=mock       # mock | sendgrid
COMMS_PROVIDER_PUSH=mock        # mock | fcm
COMMS_PROVIDER_SMS=mock         # mock | twilio
SENDGRID_API_KEY=
SENDGRID_FROM=                  # a VERIFIED sender address, or SendGrid rejects the send
FCM_SERVER_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# SECURITY GATE — OTP delivery.
# true  = OTP codes are returned in API responses (works WITHOUT email/SMS keys, but
#         anyone can read the code → MFA is bypassable). Fine for key-less testing only.
# false = codes are NOT exposed; users must receive them via SendGrid/Twilio.
# Before real users: enable SendGrid/Twilio above AND set this to false (together).
OTP_EXPOSE_DEV_CODE=true

# --- Ops portal (internal staff) --------------------------------------------------
# Ops staff are NOT customers with extra roles: they are separate accounts (ops_users)
# with their own login at /api/v1/ops/auth/**, and a typ=ops token that every member
# route refuses. Migration V8 revokes the old CARE/ADMIN grants from customer rows.
#
# REQUIRED on the deploy that first ships this, or nobody has ops access: auth-service
# creates this account on startup if it doesn't exist, with the OPS_ADMIN role.
# Afterwards: sign in, change the password, and blank OPS_BOOTSTRAP_PASSWORD again.
# (Leaving both set is harmless — an existing account is never reset.)
OPS_BOOTSTRAP_EMAIL=
OPS_BOOTSTRAP_PASSWORD=

# SECURITY GATE — ops MFA codes. Separate from OTP_EXPOSE_DEV_CODE on purpose: that one
# is true above, and sharing it would echo every ops MFA code back to the caller, making
# ops MFA meaningless while ops accounts can read every customer's data. Keep false.
OPS_OTP_EXPOSE_DEV_CODE=false

# REQUIRED — keys the tamper-evident audit hash chain (HMAC) and its signed checkpoints.
# audit-service REFUSES TO START without this outside dev/test, on purpose: an unkeyed chain
# only catches a careless UPDATE. Anyone who can write to auditdb could otherwise rewrite a row
# AND recompute every later hash, and /api/v1/audit/verify would still report "valid".
#
# NOT the same as AUDIT_INGEST_KEY: that one authenticates callers posting events; this one
# signs history. Generate a strong unique value (e.g. `openssl rand -hex 32`).
#
# CHANGING IT INVALIDATES EXISTING ROWS: every event written under the old key fails
# verification afterwards — indistinguishable from tampering. Treat it as append-only; rotating
# it needs a re-chain plan, not an edit.
AUDIT_CHAIN_KEY=CHANGE_ME_generate_a_64_char_random_secret

# --- Social sign-in (OAuth/OIDC) — blank = provider disabled + its button hidden ---
# The web reads these at RUNTIME via GET /api/v1/auth/oauth/config, so adding a value
# + restarting auth-service makes the button appear with NO web rebuild.
# Google: an OAuth *Web application* client id (Google Cloud Console → Credentials).
#   Authorized JavaScript origin MUST include your web origin (e.g. https://app.example.com).
GOOGLE_OAUTH_CLIENT_ID=
# Apple: a "Sign in with Apple" Services ID. (Apple token verification finalized when keyed.)
APPLE_OAUTH_CLIENT_ID=

# --- Scheduled jobs (optional — these have safe built-in defaults) ---
# Weekly net-worth digest email + the daily snapshot that keeps history continuous.
# SUMMARY_WEEKLY_ENABLED=true
# SUMMARY_WEEKLY_CRON=0 0 8 * * MON
# SNAPSHOT_DAILY_ENABLED=true
# SNAPSHOT_DAILY_CRON=0 30 6 * * *
