# ============================================================
#  My Wealth Management — environment template
#  Copy to .env (per service or root) and fill real values.
#  In dev, services run on H2 in-memory and these are optional
#  except where noted. Move ALL of these to a secret manager in prod.
#
#  END-TO-END DEV TESTING WITH NO KEYS: leave every *_PROVIDER on its mock default
#  and every key blank — the whole stack runs on deterministic mocks (email/SMS/push
#  log instead of sending, Plaid/AI/Stripe return fixtures). Flip one *_PROVIDER +
#  its key to exercise a real integration. No code changes either way.
# ============================================================

# --- Shared auth (MUST match across all Java services) ---
JWT_SECRET=THIS_IS_A_VERY_LONG_AND_SECURE_SECRET_KEY_FOR_JWT_AUTHENTICATION_DEMO_PURPOSES_ONLY_REPLACE_IN_PRODUCTION
JWT_EXPIRATION=86400000

# --- Database (prod profile; dev uses H2 in-memory) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wealth
POSTGRES_USER=wealth
POSTGRES_PASSWORD=change-me

# --- account-aggregation-service: Plaid (sandbox) ---
PLAID_CLIENT_ID=replace-with-your-plaid-client-id
PLAID_SECRET=replace-with-your-plaid-secret
PLAID_ENV=sandbox

# --- real-estate-service: valuation provider (Phase 3) ---
REALESTATE_PROVIDER_API_KEY=   # RentCast / ATTOM — mock used if blank

# --- business-financials-service: QuickBooks Online (Phase 4) ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8085/api/v1/business/callback
QBO_ENVIRONMENT=sandbox       # mock used if blank

# --- ai-insights-service: LLM provider (Phase 5) ---
AI_PROVIDER=mock              # mock | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-opus-4-8

# --- payment-service: Stripe (Phase 6) ---
STRIPE_SECRET_KEY=            # sk_test_... — mock used if blank
STRIPE_WEBHOOK_SECRET=

# --- notification-service (Phase 7) ---
COMMS_PROVIDER_EMAIL=mock     # mock | sendgrid
COMMS_PROVIDER_SMS=mock       # mock | twilio
COMMS_PROVIDER_PUSH=mock      # mock | fcm
SENDGRID_API_KEY=             # email — mock logs if blank
SENDGRID_FROM=                # a VERIFIED sender, or SendGrid rejects the send
FCM_SERVER_KEY=               # push — mock logs if blank
TWILIO_ACCOUNT_SID=           # sms
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Social sign-in (auth-service) — blank = provider disabled, button hidden ---
# The web reads these at runtime (GET /api/v1/auth/oauth/config); no rebuild to enable.
# For DEV, the Google OAuth Web client must allow your dev origin as an Authorized
# JavaScript origin (e.g. http://localhost:5173 for `npm run dev`, or the dev app URL).
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# --- Node legacy API ---
DATABASE_URL=file:./prisma/dev.db

# --- Web --- (these go in apps/web/.env — Vite reads them at build time)
VITE_API_BASE=http://localhost:8080
# Google Maps Places key for property address autocomplete (Properties page).
# Enable "Maps JavaScript API" + "Places API". Blank = manual address entry (graceful fallback).
VITE_GOOGLE_MAPS_API_KEY=
# DEV ONLY — skip the phone/email OTP verification requirement on signup so local
# testing doesn't need a real code. Leave UNSET (or anything but "true") in prod so
# verification stays mandatory. Set to "true" only in apps/web/.env for dev.
VITE_SKIP_SIGNUP_VERIFICATION=
