# ============================================================
#  Caddy reverse proxy — auto-HTTPS (Let's Encrypt) for the API.
#  The web app is hosted separately on Cloudflare Pages, so Caddy only
#  fronts the API gateway here. {$API_DOMAIN} / {$ACME_EMAIL} come from
#  the environment (set in docker-compose.prod.yml from .env.prod).
#
#  Local / staging without a public domain? Use the :80 block at the bottom
#  instead (comment out the {$API_DOMAIN} block) to skip TLS.
# ============================================================

{
    email {$ACME_EMAIL}
    # For Cloudflare-proxied (orange-cloud) setups, Caddy still terminates TLS at origin.
    # If you front Caddy with Cloudflare proxy, "Full (strict)" SSL mode works with this cert.
}

{$API_DOMAIN} {
    encode gzip zstd

    # Security headers. CSP allow-list reflects the origins the SPA actually loads:
    #   Google Fonts (fonts.googleapis/gstatic), jsDelivr, Google Maps, Plaid Link
    #   (cdn.plaid.com + *.plaid.com, incl. its iframe), Photon (komoot) + MyMemory
    #   for address/translation. 'unsafe-inline' is kept for styles and the small
    #   Vite/Plaid inline scripts; revisit with nonces later. After deploy, verify
    #   Plaid linking, address autocomplete, and fonts in the browser console — any
    #   blocked origin is reported there and just needs adding to the matching list.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
        Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://cdn.plaid.com https://cdn.jsdelivr.net https://maps.googleapis.com https://accounts.google.com https://appleid.cdn-apple.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; connect-src 'self' https://*.plaid.com https://maps.googleapis.com https://photon.komoot.io https://api.mymemory.translated.net https://accounts.google.com; frame-src 'self' https://cdn.plaid.com https://*.plaid.com https://accounts.google.com https://appleid.apple.com; worker-src 'self' blob:; upgrade-insecure-requests"
        -Server
    }

    # API + actuator -> the gateway. `handle` blocks are mutually exclusive and
    # evaluated in order, so these win for their paths and the SPA fallback below
    # (with try_files) never rewrites API requests.
    handle /api/* {
        reverse_proxy api-gateway:8080
    }
    handle /actuator/* {
        reverse_proxy api-gateway:8080
    }
    # Everything else -> the web single-page app (mounted at /srv from apps/web/dist)
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}

# Canonical redirect: the bare domain + www -> the single app origin (app.terravest.app).
# Caddy auto-issues certs for these too. (Keeps one canonical URL; good for SEO/cookies.)
terravest.app, www.terravest.app {
    redir https://app.terravest.app{uri} permanent
}

# ------------------------------------------------------------
# Plain-HTTP fallback for local prod-like runs without a domain.
# Uncomment and comment the block above. Then hit http://localhost.
# ------------------------------------------------------------
# :80 {
#     encode gzip zstd
#     reverse_proxy api-gateway:8080
# }
