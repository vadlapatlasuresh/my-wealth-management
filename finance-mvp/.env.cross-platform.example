# ============================================================
#  TerraVest — cross-platform secrets & provider keys template
#  Copy to .env (root and/or per-service) and fill real values.
#  This file documents EVERY key the owner must supply later.
#
#  Convention: keys marked [OPTIONAL] use a built-in MOCK if left
#  blank, so the app still runs in dev without them. Keys marked
#  [REQUIRED] must be set for that feature/service to work.
#  Move ALL real secrets to a secret manager in production.
# ============================================================

# ── Shared auth — MUST match across all Java services ──────── [REQUIRED]
# 256-bit+ random string. Same value in every service or tokens won't verify.
JWT_SECRET=replace-with-a-long-random-secret-min-64-chars
JWT_EXPIRATION=86400000                 # token lifetime in ms (default 24h)
APP_ENCRYPTION_KEY=                      # [REQUIRED in prod] AES key for Plaid token encryption (openssl rand -base64 32)

# ── Plaid — account-aggregation-service (bank/account linking) ─
PLAID_CLIENT_ID=                        # [OPTIONAL] Plaid client id — mock used if blank
PLAID_SECRET=                           # [OPTIONAL] Plaid secret — mock used if blank
PLAID_ENV=sandbox                       # sandbox | development | production

# ── Stripe — payment-service (subscriptions / payments) ──────
PAYMENT_PROVIDER=mock                   # mock | stripe  — set 'stripe' to create real PaymentIntents
STRIPE_SECRET_KEY=                      # [OPTIONAL] sk_test_... / sk_live_... — mock used if blank
STRIPE_WEBHOOK_SECRET=                  # [OPTIONAL] whsec_... — verify webhook signatures

# ── SMS — notification-service (one of the two providers) ────
COMMS_PROVIDER_SMS=mock                 # mock | twilio  — set 'twilio' to send real SMS
# Twilio (preferred)
TWILIO_ACCOUNT_SID=                     # [OPTIONAL] AC... — mock logs if blank
TWILIO_AUTH_TOKEN=                      # [OPTIONAL] Twilio auth token
TWILIO_FROM=                            # [OPTIONAL] +1XXXXXXXXXX sending number
# OR AWS SNS (alternative to Twilio — leave Twilio blank if using SNS)
AWS_SNS_REGION=                         # [OPTIONAL] e.g. us-east-1
AWS_SNS_ACCESS_KEY_ID=                  # [OPTIONAL]
AWS_SNS_SECRET_ACCESS_KEY=              # [OPTIONAL]

# ── Email — notification-service (one of the two providers) ──
COMMS_PROVIDER_EMAIL=mock               # mock | sendgrid  — set 'sendgrid' to send real email
SENDGRID_API_KEY=                       # [OPTIONAL] SG... — mock logs if blank
SENDGRID_FROM=                          # [OPTIONAL] verified sender, e.g. no-reply@terravest.app
# OR AWS SES (alternative to SendGrid)
AWS_SES_REGION=                         # [OPTIONAL] e.g. us-east-1
AWS_SES_ACCESS_KEY_ID=                  # [OPTIONAL]
AWS_SES_SECRET_ACCESS_KEY=              # [OPTIONAL]
EMAIL_FROM=no-reply@terravest.app       # [OPTIONAL] default from address

# ── Push notifications — notification-service + mobile shell ──
COMMS_PROVIDER_PUSH=mock                # mock | fcm  — set 'fcm' to send real push
FCM_SERVER_KEY=                         # [OPTIONAL] Android/cross FCM key — mock logs if blank
APNS_KEY_ID=                            # [OPTIONAL] Apple Push key id
APNS_TEAM_ID=                           # [OPTIONAL] Apple developer team id
APNS_BUNDLE_ID=com.terravest.app        # [OPTIONAL] must match Capacitor appId
APNS_AUTH_KEY_PATH=                     # [OPTIONAL] path to AuthKey_XXXX.p8
EXPO_ACCESS_TOKEN=                      # [OPTIONAL] only if using Expo push instead of FCM/APNS

# ── AI — ai-insights-service (LLM provider) ──────────────────
AI_PROVIDER=mock                        # mock | anthropic | openai  ([OPTIONAL] mock if blank)
ANTHROPIC_API_KEY=                      # [OPTIONAL] sk-ant-... — required if AI_PROVIDER=anthropic
OPENAI_API_KEY=                         # [OPTIONAL] sk-... — required if AI_PROVIDER=openai
AI_MODEL=claude-opus-4-8                # model id for the chosen provider

# ── Managed feature flags ────────────────────────────────────
LAUNCHDARKLY_SDK_KEY=                   # [OPTIONAL] sdk-... — local/DB flags used if blank

# ── Headless CMS / content (disclaimers, marketing copy) ─────
CMS_API_URL=                            # [OPTIONAL] content API base — DB content API used if blank
CMS_API_TOKEN=                          # [OPTIONAL] read token for the CMS

# ── Capacitor / EAS mobile signing ───────────────────────────
# iOS (App Store / TestFlight)
APPLE_TEAM_ID=                          # [OPTIONAL until release] Apple developer team id
IOS_DISTRIBUTION_CERT_BASE64=           # [OPTIONAL until release] base64 .p12 cert
IOS_PROVISIONING_PROFILE_BASE64=        # [OPTIONAL until release] base64 mobileprovision
APPLE_APP_SPECIFIC_PASSWORD=            # [OPTIONAL until release] for notarize/upload
# Android (Play Store)
ANDROID_KEYSTORE_BASE64=                # [OPTIONAL until release] base64 .jks/.keystore
ANDROID_KEYSTORE_PASSWORD=              # [OPTIONAL until release]
ANDROID_KEY_ALIAS=                      # [OPTIONAL until release]
ANDROID_KEY_PASSWORD=                   # [OPTIONAL until release]
# EAS (only if using Expo Application Services for builds)
EXPO_TOKEN=                             # [OPTIONAL] EAS build/submit token

# ── Web (apps/web/.env — Vite reads VITE_* at build time) ────
VITE_API_BASE=http://localhost:8080     # [REQUIRED] api-gateway base URL
VITE_GOOGLE_MAPS_API_KEY=               # [OPTIONAL] Places autocomplete — manual entry if blank

# ── Auto-translation (i18n: whole-app machine translation) ───
# The UI auto-detects the user's language and the WHOLE app translates on switch.
# Chrome ships human translations (en,es,fr,de,pt,zh,hi,ja,ar); page bodies are
# machine-translated at runtime and cached. By DEFAULT this uses MyMemory (free,
# no key) so it works with zero config. For scale/production, self-host
# LibreTranslate and set the endpoint below (takes precedence over MyMemory).
VITE_TRANSLATE_ENDPOINT=                 # [OPTIONAL] e.g. https://libretranslate.example.com/translate
VITE_TRANSLATE_API_KEY=                  # [OPTIONAL] provider key if the endpoint requires one
VITE_TRANSLATE_EMAIL=                    # [OPTIONAL] raises the free MyMemory quota when using the default
