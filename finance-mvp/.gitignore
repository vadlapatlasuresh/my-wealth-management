node_modules
dist
.DS_Store
*.log

# Build artifacts — never commit compiled output (regenerated by the build)
# Maven output for every Spring service (apps/*/target)
target/
# Capacitor/Xcode native build output incl. multi-GB V8 compilation cache
apps/web/build/
apps/web/ios/App/build/
apps/web/android/app/build/
*.class

# Secrets — never commit any real env file (only *.example is tracked)
.env
.env.*
!.env*.example
**/.env
**/.env.*
!**/.env*.example
