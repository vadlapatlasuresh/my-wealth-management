{
  "_comment": "Catalog of every secret the platform needs. Seeded with PLACEHOLDER values on first boot (REPLACE_ME::<name>). Set real values with POST /admin/secrets/{name}/rotate. DB creds follow the same pattern with scope db.<service>.",
  "secrets": [
    {
      "name": "jwt.secret",
      "scope": "jwt",
      "description": "Shared HS256 JWT signing key (all services)",
      "rotationDays": 90
    },
    {
      "name": "app.encryption_key",
      "scope": "encryption",
      "description": "AES-256 key material for PII/Plaid-token at-rest encryption",
      "rotationDays": 180
    },
    {
      "name": "audit.ingest_key",
      "scope": "audit",
      "description": "Internal key to post audit events",
      "rotationDays": 90
    },
    {
      "name": "notifications.internal_key",
      "scope": "notifications-internal",
      "description": "Internal key real-estate -> notification ingest",
      "rotationDays": 90
    },
    {
      "name": "plaid.client_id",
      "scope": "plaid",
      "description": "Plaid client id"
    },
    {
      "name": "plaid.secret",
      "scope": "plaid",
      "description": "Plaid secret (sandbox/production)",
      "rotationDays": 180
    },
    {
      "name": "stripe.secret_key",
      "scope": "stripe",
      "description": "Stripe API secret key (sk_...)",
      "rotationDays": 180
    },
    {
      "name": "stripe.webhook_secret",
      "scope": "stripe",
      "description": "Stripe webhook signing secret (whsec_...)"
    },
    {
      "name": "sendgrid.api_key",
      "scope": "sendgrid",
