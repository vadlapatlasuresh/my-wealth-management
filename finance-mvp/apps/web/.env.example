# Web app environment (Vite). Copy to .env and fill in.

# API Gateway base URL
VITE_API_BASE=http://localhost:8080

# Google Maps Places — enables address autocomplete on the Properties page.
# Create a key in Google Cloud Console and enable "Maps JavaScript API" + "Places API".
# Leave blank to use a plain manual address input (feature degrades gracefully).
VITE_GOOGLE_MAPS_API_KEY=
